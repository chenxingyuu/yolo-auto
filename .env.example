YOLO_SSH_HOST=127.0.0.1
YOLO_SSH_PORT=2222
YOLO_SSH_USER=yolo
YOLO_SSH_KEY_PATH=/Users/yourname/.ssh/id_rsa

FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxx
# 应用机器人（推荐，用于发送图片等能力）。若设置了这三项，可不填 FEISHU_WEBHOOK_URL
FEISHU_APP_ID=cli_xxxx
FEISHU_APP_SECRET=xxxx
FEISHU_CHAT_ID=oc_xxxx
FEISHU_REPORT_ENABLE=true
FEISHU_REPORT_EVERY_N_EPOCHS=5
# 可选：schema 2.0 训练卡片顶部图片 key（image_key）
FEISHU_CARD_IMG_KEY=
# 可选：顶部图片 fallback key（image_key）
FEISHU_CARD_FALLBACK_IMG_KEY=
YOLO_PRIMARY_METRIC=map5095

MLFLOW_TRACKING_URI=sqlite:////data/mlflow/mlflow.db
MLFLOW_EXPERIMENT_NAME=yolo-auto
# 外部可访问的 MLflow UI 地址（用于在飞书卡片中生成可点击链接）。局域网访问时请填 http://<本机局域网IP>:5001
MLFLOW_EXTERNAL_URL=http://localhost:5001
# 可选：yolo://mlflow/leaderboard 仅包含满足条件的 runs（MLflow search_runs 的 filter_string）
# 例如：tags.yolo_data_stem = 'coco128'
MLFLOW_LEADERBOARD_FILTER=

YOLO_WORK_DIR=/workspace/yolo-auto
YOLO_DATASETS_DIR=/workspace/datasets
YOLO_JOBS_DIR=/workspace/jobs
YOLO_MODELS_DIR=/workspace/models
YOLO_STATE_FILE=.state/jobs.db
YOLO_WATCH_POLL_INTERVAL_SECONDS=30
YOLO_WATCH_LOCK_FILE=.state/watch.lock
YOLO_MINIO_ALIAS=minio
YOLO_MINIO_EXPORT_BUCKET=cvat-export
YOLO_MINIO_EXPORT_PREFIX=exports
